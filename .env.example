# Modo de operacion: beta o prod
MODE=beta

# Database (Postgres local o Supabase)
DATABASE_URL=postgresql://postgres:password@localhost:5432/sis_facturador_dev

# Storage backend: "local" (filesystem) o "supabase" (cloud, requerido para Vercel)
STORAGE_BACKEND=local
# Carpeta para storage local (vacio = <repo>/storage)
LOCAL_STORAGE_DIR=

# Solo si STORAGE_BACKEND=supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=comprobantes

# SUNAT (credenciales SOL del emisor)
SUNAT_RUC=20000000001
SUNAT_USER=MODDATOS
SUNAT_PASSWORD=MODDATOS

# Certificado digital .pfx codificado en base64
# Generar en Windows con:
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("MODDATOS.pfx"))
CERT_PFX_BASE64=
CERT_PASSWORD=MODDATOS

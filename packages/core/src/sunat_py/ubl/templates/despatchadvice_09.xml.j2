<?xml version="1.0" encoding="UTF-8"?>
<DespatchAdvice xmlns="urn:oasis:names:specification:ubl:schema:xsd:DespatchAdvice-2"
               xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
               xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2"
               xmlns:ext="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
               xmlns:ds="http://www.w3.org/2000/09/xmldsig#">
  <ext:UBLExtensions>
    <ext:UBLExtension>
      <ext:ExtensionContent/>
    </ext:UBLExtension>
  </ext:UBLExtensions>
  <cbc:UBLVersionID>2.1</cbc:UBLVersionID>
  <cbc:CustomizationID>2.0</cbc:CustomizationID>
  <cbc:ID>{{ inv.serie }}-{{ inv.numero }}</cbc:ID>
  <cbc:IssueDate>{{ inv.fecha_emision.isoformat() }}</cbc:IssueDate>
  <cbc:IssueTime>00:00:00</cbc:IssueTime>
  <cbc:DespatchAdviceTypeCode listAgencyName="PE:SUNAT"
                              listName="Tipo de Documento"
                              listURI="urn:pe:gob:sunat:cpe:see:gem:catalogos:catalogo01">09</cbc:DespatchAdviceTypeCode>
  <cbc:Note>{{ inv.motivo_descripcion }}</cbc:Note>
  <cac:Signature>
    <cbc:ID>SIGN{{ inv.emisor.numero_doc }}</cbc:ID>
    <cac:SignatoryParty>
      <cac:PartyIdentification>
        <cbc:ID>{{ inv.emisor.numero_doc }}</cbc:ID>
      </cac:PartyIdentification>
      <cac:PartyName>
        <cbc:Name>{{ inv.emisor.razon_social }}</cbc:Name>
      </cac:PartyName>
    </cac:SignatoryParty>
    <cac:DigitalSignatureAttachment>
      <cac:ExternalReference>
        <cbc:URI>#SignatureSP</cbc:URI>
      </cac:ExternalReference>
    </cac:DigitalSignatureAttachment>
  </cac:Signature>
  <cac:DespatchSupplierParty>
    <cac:Party>
      <cac:PartyIdentification>
        <cbc:ID schemeID="6" schemeName="Documento de Identidad" schemeAgencyName="PE:SUNAT" schemeURI="urn:pe:gob:sunat:cpe:see:gem:catalogos:catalogo06">{{ inv.emisor.numero_doc }}</cbc:ID>
      </cac:PartyIdentification>
      <cac:PartyLegalEntity>
        <cbc:RegistrationName>{{ inv.emisor.razon_social }}</cbc:RegistrationName>
      </cac:PartyLegalEntity>
    </cac:Party>
  </cac:DespatchSupplierParty>
  <cac:DeliveryCustomerParty>
    <cac:Party>
      <cac:PartyIdentification>
        <cbc:ID schemeID="{{ inv.destinatario.tipo_doc }}" schemeName="Documento de Identidad" schemeAgencyName="PE:SUNAT" schemeURI="urn:pe:gob:sunat:cpe:see:gem:catalogos:catalogo06">{{ inv.destinatario.numero_doc }}</cbc:ID>
      </cac:PartyIdentification>
      <cac:PartyLegalEntity>
        <cbc:RegistrationName>{{ inv.destinatario.razon_social }}</cbc:RegistrationName>
      </cac:PartyLegalEntity>
    </cac:Party>
  </cac:DeliveryCustomerParty>
  <cac:Shipment>
    <cbc:ID>SUNAT_Envio</cbc:ID>
    <cbc:HandlingCode listAgencyName="PE:SUNAT"
                     listName="Motivo de traslado"
                     listURI="urn:pe:gob:sunat:cpe:see:gem:catalogos:catalogo20">{{ inv.motivo_traslado }}</cbc:HandlingCode>
    <cbc:HandlingInstructions>{{ inv.motivo_descripcion }}</cbc:HandlingInstructions>
    <cbc:GrossWeightMeasure unitCode="{{ inv.peso_bruto_unidad }}">{{ peso_bruto }}</cbc:GrossWeightMeasure>
    {% if inv.numero_bultos != none %}
    <cbc:TotalTransportHandlingUnitQuantity>{{ inv.numero_bultos }}</cbc:TotalTransportHandlingUnitQuantity>
    {% endif %}
    <cac:ShipmentStage>
      <cbc:TransportModeCode listAgencyName="PE:SUNAT"
                            listName="Modalidad de traslado"
                            listURI="urn:pe:gob:sunat:cpe:see:gem:catalogos:catalogo18">{{ inv.modalidad }}</cbc:TransportModeCode>
      <cac:TransitPeriod>
        <cbc:StartDate>{{ (inv.fecha_inicio_traslado or inv.fecha_emision).isoformat() }}</cbc:StartDate>
      </cac:TransitPeriod>
      {% if inv.modalidad == "01" and inv.transportista %}
      <cac:CarrierParty>
        <cac:PartyIdentification>
          <cbc:ID schemeID="6">{{ inv.transportista.numero_doc }}</cbc:ID>
        </cac:PartyIdentification>
        <cac:PartyLegalEntity>
          <cbc:RegistrationName>{{ inv.transportista.razon_social }}</cbc:RegistrationName>
        </cac:PartyLegalEntity>
      </cac:CarrierParty>
      {% endif %}
      {% if inv.conductor %}
      <cac:DriverPerson>
        <cbc:ID schemeID="{{ inv.conductor.tipo_doc }}" schemeName="Documento de Identidad" schemeAgencyName="PE:SUNAT" schemeURI="urn:pe:gob:sunat:cpe:see:gem:catalogos:catalogo06">{{ inv.conductor.numero_doc }}</cbc:ID>
        <cbc:FirstName>{{ inv.conductor.nombres }}</cbc:FirstName>
        <cbc:FamilyName>{{ inv.conductor.apellidos }}</cbc:FamilyName>
        <cbc:JobTitle>Principal</cbc:JobTitle>
        <cac:IdentityDocumentReference>
          <cbc:ID>{{ inv.conductor.licencia }}</cbc:ID>
        </cac:IdentityDocumentReference>
      </cac:DriverPerson>
      {% endif %}
    </cac:ShipmentStage>
    <cac:Delivery>
      <cac:DeliveryAddress>
        <cbc:ID schemeAgencyName="PE:INEI" schemeName="Ubigeos">{{ inv.llegada.ubigeo }}</cbc:ID>
        {% if inv.llegada.cod_local %}
        <cbc:AddressTypeCode listID="{{ inv.emisor.numero_doc }}">{{ inv.llegada.cod_local }}</cbc:AddressTypeCode>
        {% endif %}
        <cac:AddressLine>
          <cbc:Line>{{ inv.llegada.direccion }}</cbc:Line>
        </cac:AddressLine>
      </cac:DeliveryAddress>
      <cac:Despatch>
        <cac:DespatchAddress>
          <cbc:ID schemeAgencyName="PE:INEI" schemeName="Ubigeos">{{ inv.partida.ubigeo }}</cbc:ID>
          {% if inv.partida.cod_local %}
          <cbc:AddressTypeCode listID="{{ inv.emisor.numero_doc }}">{{ inv.partida.cod_local }}</cbc:AddressTypeCode>
          {% endif %}
          <cac:AddressLine>
            <cbc:Line>{{ inv.partida.direccion }}</cbc:Line>
          </cac:AddressLine>
        </cac:DespatchAddress>
      </cac:Despatch>
    </cac:Delivery>
    {% if inv.vehiculo %}
    <cac:TransportHandlingUnit>
      <cac:TransportEquipment>
        <cbc:ID>{{ inv.vehiculo.placa }}</cbc:ID>
      </cac:TransportEquipment>
    </cac:TransportHandlingUnit>
    {% endif %}
  </cac:Shipment>
  {% for line in lines %}
  <cac:DespatchLine>
    <cbc:ID>{{ loop.index }}</cbc:ID>
    <cbc:DeliveredQuantity unitCode="{{ line.unidad }}">{{ line.cantidad }}</cbc:DeliveredQuantity>
    <cac:OrderLineReference>
      <cbc:LineID>{{ loop.index }}</cbc:LineID>
    </cac:OrderLineReference>
    <cac:Item>
      <cbc:Description>{{ line.descripcion }}</cbc:Description>
      <cac:SellersItemIdentification>
        <cbc:ID>{{ line.codigo }}</cbc:ID>
      </cac:SellersItemIdentification>
    </cac:Item>
  </cac:DespatchLine>
  {% endfor %}
</DespatchAdvice>
